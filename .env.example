# ============================================
# ShopMind Configuration
# Copy this file to .env and fill in your values
# ============================================

# Required — your Bailian (百炼) API key
BAILIAN_API_KEY=sk-your-bailian-api-key-here

# LLM Configuration
BAILIAN_LLM_MODEL=qwen-max
BAILIAN_EMBEDDING_MODEL=text-embedding-v2
# Workspace-based endpoint:
BAILIAN_BASE_URL=https://ws-xxxxxxxxxxxxxx.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# Or standard DashScope:
# BAILIAN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Database (auto-resolved from project root, override if needed)
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=kb_chunks

# Retrieval
RETRIEVAL_K=8
RETRIEVAL_FETCH_K=20
RETRIEVAL_LAMBDA_MULT=0.7

# Auth
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
BCRYPT_ROUNDS=12

# Admin Seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# Rate Limiting
RATE_LIMIT_ENABLED=true

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=["pdf","txt","csv","md","docx","html"]

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Application
APP_NAME=ShopMind
APP_VERSION=1.0.0
DEBUG=false
